{
  "manifest_version": 3,
  "name": "Kuery (capture shim)",
  "version": "0.2.0",
  "description": "Captures Kusto queries executed in Azure Data Explorer and forwards them to the Kuery desktop app over HTTP.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://dataexplorer.azure.com/*",
    "https://*.kusto.windows.net/*",
    "http://127.0.0.1:47821/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://dataexplorer.azure.com/*",
        "https://*.kusto.windows.net/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": [
        "https://dataexplorer.azure.com/*",
        "https://*.kusto.windows.net/*"
      ]
    }
  ],
  "icons": { "128": "icons/icon128.png" }
}
